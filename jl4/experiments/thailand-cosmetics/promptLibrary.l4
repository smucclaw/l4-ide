// Thailand Cosmetics - Complete Prompt Library (Functional)
// Converted from 11-article41-complete-prompts.l4 static strings to callable functions
//
// Each prompt function takes claimText as parameter and returns formatted prompt string
// Total: 51 prompts (9 Tier 3 + 7 Tier 2 + 35 Tier 1)

§ `Thailand Cosmetics Prompt Library`

// ============================================================================
// TIER 3: CORE ARTICLE 41 PROMPTS (9 prompts - apply to ALL cosmetics)
// Source: Thai Cosmetics Act BE 2558, Article 41 & 42
// ============================================================================

// PROMPT 1: Article 41.2.1 - False or Exaggerated Claims
promptFalseOrExaggerated claimText MEANS
  CONCAT
    "REGULATORY TEST: False or Exaggerated Claims (Article 41.2.1)\n",
    "Context: Thai Cosmetics Act BE 2558, Article 41, Paragraph 2(1)\n\n",
    "Principle: Cosmetic advertising must not contain statements that are false or\n",
    "exaggerate beyond truth regarding the nature, quality, quantity, or other\n",
    "essential characteristics of the cosmetic. Claims must be truthful and\n",
    "proportionate to available evidence.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE (truthful, proportionate claims):\n",
    "  - Claims supported by verifiable evidence\n",
    "  - Proportionate language: \"helps\", \"may\", \"can improve\"\n",
    "  - Results qualified: \"results may vary\", \"during period of use\"\n",
    "  - Factual descriptions of actual ingredients/properties\n",
    "  - Comparison with own products (with data support)\n\n",
    "❌ PROHIBITED (false or exaggerated):\n",
    "  - Factually untrue statements\n",
    "  - Extreme exaggerations: \"transforms completely\", \"miracle\", \"revolutionary\"\n",
    "  - Absolute guarantees without basis: \"100% effective\", \"guaranteed results\"\n",
    "  - Overstating speed: \"instant permanent change\", \"immediate transformation\"\n",
    "  - Overstating degree: \"eliminates all wrinkles\", \"perfect skin\"\n",
    "  - Fabricated test results or credentials\n",
    "  - Unverifiable superlatives: \"world's best\", \"the best\", \"non-toxic\",\n",
    "    \"no side effects\", \"solves all problems\"\n",
    "  - Comparison to medical procedures: \"equals Botox\", \"like laser treatment\"\n",
    "  - False FDA certification: \"FDA certified quality\", \"FDA approved safety\"\n\n",
    "Examples from Manual:\n",
    "  - ❌ \"Face-lifting set... golden miracle... Within 28 days, tightens skin,\n",
    "       locks age, firms and slims face... restores sagging skin to perfection\"\n",
    "  - ❌ \"Just applying equals injections\"\n",
    "  - ❌ \"Results more remarkable than Botox\"\n",
    "  - ❌ \"Complies with standards from the Food and Drug Administration\"\n\n",
    "Key distinction: Proportionate truthful claims ✓ vs. false or exaggerated claims ✗\n\n",
    "Note: Utterly unrealistic claims obvious to public may qualify for puffery\n",
    "exemption (Article 41.3) - evaluate separately.\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Is this claim FALSE (factually untrue) or EXAGGERATED (overstates\n",
    "truth beyond what evidence could support)?\n\n",
    "Answer with:\n",
    "- YES (violates 41.2.1 - prohibited) or NO (acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 2: Article 41.2.2 - Misleading Scientific References
promptMisleadingScientificRefs claimText MEANS
  CONCAT
    "REGULATORY TEST: Misleading Scientific References (Article 41.2.2)\n",
    "Context: Thai Cosmetics Act BE 2558, Article 41, Paragraph 2(2)\n\n",
    "Principle: Cosmetic advertising must not use or cite academic reports,\n",
    "statistics, or any other sources in a way that may mislead consumers on\n",
    "essential aspects of the cosmetic, whether the claims are true or exaggerated.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE (non-misleading citations):\n",
    "  - Accurate citations of relevant scientific research\n",
    "  - Clear indication of study scope and limitations\n",
    "  - Statistical data presented in proper context\n",
    "  - Academic references that support the specific claim made\n",
    "  - Proper attribution to credible sources\n\n",
    "❌ PROHIBITED (misleading use of science):\n",
    "  - Cherry-picking data to misrepresent conclusions\n",
    "  - Citing studies about ingredients not present in sufficient quantity\n",
    "  - Implying causation from correlational studies\n",
    "  - Misquoting or misrepresenting academic sources\n",
    "  - Using scientific-sounding language without actual evidence\n",
    "  - Citing irrelevant studies to create false authority\n",
    "  - Presenting in vitro results as if they were clinical outcomes\n",
    "  - Using statistical significance to imply practical significance\n\n",
    "Examples from Manual:\n",
    "  - ❌ \"Clinically proven\" without actual clinical trial data\n",
    "  - ❌ Citing ingredient studies for formulations with trace amounts\n",
    "  - ❌ \"Dermatologically tested\" without clarifying what was tested\n\n",
    "Key distinction: Accurate, contextual science ✓ vs. misleading science use ✗\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this claim cite or use scientific/academic information in a way\n",
    "that could mislead consumers about the product's essential characteristics?\n\n",
    "Answer with:\n",
    "- YES (violates 41.2.2 - prohibited) or NO (acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 3: Article 41.2.3 - Medicinal/Therapeutic Claims
promptMedicinalTherapeutic claimText MEANS
  CONCAT
    "REGULATORY TEST: Medicinal/Therapeutic Claims (Article 41.2.3)\n",
    "Context: Thai Cosmetics Act BE 2558, Article 41, Paragraph 2(3)\n\n",
    "Principle: Cosmetic advertising must not state or imply that the cosmetic has\n",
    "properties to prevent, treat, cure, or alleviate diseases or symptoms. Cosmetics\n",
    "are for cleansing, beautifying, or changing appearance - not medical treatment.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE (cosmetic purpose):\n",
    "  - \"helps maintain\", \"supports appearance\"\n",
    "  - \"cleanses\", \"beautifies\", \"enhances appearance\"\n",
    "  - \"for [skin type]\", \"suitable for sensitive skin\"\n",
    "  - \"makes skin look/appear [quality]\"\n",
    "  - \"temporary cosmetic effect during use\"\n\n",
    "❌ PROHIBITED (medicinal/therapeutic):\n",
    "  - \"treats\", \"cures\", \"heals\", \"prevents\", \"alleviates\"\n",
    "  - Disease/condition names: \"treats acne\", \"cures eczema\", \"prevents infection\"\n",
    "  - Symptom relief: \"reduces pain\", \"relieves inflammation\"\n",
    "  - Physiological changes: \"increases collagen\", \"boosts immunity\", \"repairs DNA\"\n",
    "  - Disease prevention: \"prevents cancer\", \"protects against bacteria\"\n",
    "  - Medical terminology: \"anti-bacterial\", \"anti-fungal\", \"clinical treatment\"\n\n",
    "Examples from Manual:\n",
    "  - ✅ \"Formulated for acne-prone skin\"\n",
    "  - ❌ \"Treats acne\", \"eliminates acne permanently\"\n",
    "  - ❌ \"Prevents wrinkles by stimulating collagen production\"\n",
    "  - ❌ \"Heals damaged skin\", \"repairs skin barrier function\"\n\n",
    "Key distinction: Cosmetic appearance ✓ vs. medical treatment ✗\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this claim imply the product prevents, treats, cures, or\n",
    "alleviates diseases or medical conditions?\n\n",
    "Answer with:\n",
    "- YES (violates 41.2.3 - prohibited) or NO (acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 4: Article 41.2.4 - Sexual Enhancement Claims
promptSexualEnhancement claimText MEANS
  CONCAT
    "REGULATORY TEST: Sexual Enhancement Claims (Article 41.2.4)\n",
    "Context: Thai Cosmetics Act BE 2558, Article 41, Paragraph 2(4)\n\n",
    "Principle: Cosmetic advertising must not state or imply that the cosmetic can\n",
    "enhance sexual potency, increase libido, improve sexual performance, or provide\n",
    "aphrodisiac effects.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE (cosmetic enhancement):\n",
    "  - \"enhances confidence\", \"makes you feel attractive\"\n",
    "  - \"beautiful appearance\", \"radiant skin\"\n",
    "  - \"feeling refreshed\", \"energized feeling\"\n",
    "  - Fragrance creating pleasant mood\n\n",
    "❌ PROHIBITED (sexual enhancement):\n",
    "  - \"increases libido\", \"enhances sexual desire\"\n",
    "  - \"improves sexual performance\", \"boosts potency\"\n",
    "  - \"aphrodisiac effect\", \"stimulates passion\"\n",
    "  - \"enhances sexual attraction\" (beyond appearance)\n",
    "  - Pheromone claims implying sexual effects\n",
    "  - \"increases blood flow\" (with sexual connotation)\n\n",
    "Key distinction: Appearance/confidence ✓ vs. sexual function ✗\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this claim state or imply effects on sexual potency, libido,\n",
    "performance, or aphrodisiac properties?\n\n",
    "Answer with:\n",
    "- YES (violates 41.2.4 - prohibited) or NO (acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 5: Article 41.2.5 - Illegal/Immoral Content
promptIllegalImmoral claimText MEANS
  CONCAT
    "REGULATORY TEST: Illegal/Immoral Content (Article 41.2.5)\n",
    "Context: Thai Cosmetics Act BE 2558, Article 41, Paragraph 2(5)\n\n",
    "Principle: Cosmetic advertising must not include statements that promote,\n",
    "support, or encourage illegal activities, criminal behavior, or immoral conduct\n",
    "that degrades public morals or social values.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE:\n",
    "  - Promoting beauty, health, self-care\n",
    "  - Encouraging confidence, positive self-image\n",
    "  - Celebrating diversity, individual expression\n",
    "  - Standard commercial persuasion\n\n",
    "❌ PROHIBITED:\n",
    "  - Encouraging illegal activity or crime\n",
    "  - Promoting substance abuse\n",
    "  - Encouraging dangerous behavior\n",
    "  - Content that degrades public morals\n",
    "  - Exploitative or degrading imagery/language\n",
    "  - Promoting deception or dishonesty\n\n",
    "Key distinction: Lawful persuasion ✓ vs. illegal/immoral promotion ✗\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this claim promote, support, or encourage illegal activities,\n",
    "criminal behavior, or immoral conduct that degrades public morals?\n\n",
    "Answer with:\n",
    "- YES (violates 41.2.5 - prohibited) or NO (acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 6: Article 41.2.6 - Social Division
promptSocialDivision claimText MEANS
  CONCAT
    "REGULATORY TEST: Social Division/Disunity (Article 41.2.6)\n",
    "Context: Thai Cosmetics Act BE 2558, Article 41, Paragraph 2(6)\n\n",
    "Principle: Cosmetic advertising must not cause or incite dissension, division,\n",
    "or disunity among the people of the nation.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE:\n",
    "  - Celebrating beauty diversity\n",
    "  - Marketing to specific demographics (age, skin type)\n",
    "  - Regional product variations\n",
    "  - Cultural celebration (inclusive)\n\n",
    "❌ PROHIBITED:\n",
    "  - Disparaging ethnic, regional, or social groups\n",
    "  - Creating division between social classes\n",
    "  - Inflammatory political content\n",
    "  - Religious divisiveness\n",
    "  - Stereotyping that breeds discord\n",
    "  - \"Us vs. them\" rhetoric creating social division\n\n",
    "Key distinction: Inclusive marketing ✓ vs. divisive content ✗\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this claim cause or incite dissension, division, or disunity\n",
    "among people?\n\n",
    "Answer with:\n",
    "- YES (violates 41.2.6 - prohibited) or NO (acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 7: Article 41.2.7 - Ministerial Regulations
promptMinisterialRegulations claimText MEANS
  CONCAT
    "REGULATORY TEST: Ministerial Regulations (Article 41.2.7)\n",
    "Context: Thai Cosmetics Act BE 2558, Article 41, Paragraph 2(7)\n\n",
    "Principle: Cosmetic advertising must not violate prohibitions established in\n",
    "ministerial regulations issued under the Cosmetics Act.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE:\n",
    "  - Compliance with all ministerial regulations\n",
    "  - Proper labeling as required\n",
    "  - Appropriate product notifications\n",
    "  - Following category-specific rules\n\n",
    "❌ PROHIBITED:\n",
    "  - Violations of Manual on Cosmetic Advertising BE 2567\n",
    "  - Violations of category-specific regulations\n",
    "  - Failure to comply with labeling requirements\n",
    "  - Unauthorized claims for controlled cosmetic categories\n\n",
    "Note: This is a catch-all for specific ministerial rules. Specific violations\n",
    "should be evaluated using the appropriate category-specific or Manual-specific\n",
    "prompts.\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this claim violate specific ministerial regulations under the\n",
    "Cosmetics Act?\n\n",
    "Answer with:\n",
    "- YES (violates 41.2.7 - prohibited) or NO (acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 8: Article 41.3 - Puffery Exemption
promptPufferyExemption claimText MEANS
  CONCAT
    "REGULATORY TEST: Puffery Exemption (Article 41.3)\n",
    "Context: Thai Cosmetics Act BE 2558, Article 41, Paragraph 3\n\n",
    "Principle: False or exaggerated claims (41.2.1) may be exempted if they are\n",
    "UTTERLY UNREALISTIC statements that the general public obviously knows are\n",
    "exaggerations and would not rely upon.\n\n",
    "Decision Boundary:\n",
    "✅ QUALIFIES FOR PUFFERY EXEMPTION (obviously unrealistic):\n",
    "  - \"Fountain of youth\"\n",
    "  - \"Makes you look 20 years younger overnight\"\n",
    "  - \"Turns back time\"\n",
    "  - Fantastical imagery everyone knows is symbolic\n",
    "  - Obviously hyperbolic marketing language\n\n",
    "❌ DOES NOT QUALIFY (could be believed):\n",
    "  - \"Reduces wrinkles by 50%\" (sounds scientific/measurable)\n",
    "  - \"Clinically proven\" (implies evidence)\n",
    "  - \"100% effective\" (sounds factual)\n",
    "  - \"Guaranteed results\" (sounds like a promise)\n",
    "  - Any claim the average consumer might actually believe\n\n",
    "Important: This exemption ONLY applies to false/exaggerated claims (41.2.1).\n",
    "It does NOT exempt medicinal claims, sexual claims, illegal content, etc.\n\n",
    "Key distinction: Obvious fantasy ✓ vs. believable claims ✗\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Is this claim so UTTERLY UNREALISTIC that the general public obviously\n",
    "knows it's an exaggeration and would not rely upon it?\n\n",
    "Answer with:\n",
    "- YES (qualifies for puffery exemption) or NO (does not qualify)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 9: Article 42 - Harmful Advertising Conduct
promptHarmfulConduct claimText MEANS
  CONCAT
    "REGULATORY TEST: Harmful Advertising Conduct (Article 42)\n",
    "Context: Thai Cosmetics Act BE 2558, Article 42\n\n",
    "Principle: Cosmetic advertising must not be conducted in a manner that may harm\n",
    "health, mentality, or morality, or cause distress or excessive inconvenience.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE (respectful advertising methods):\n",
    "  - Standard media advertising (TV, print, online)\n",
    "  - Respectful in-store promotions\n",
    "  - Opt-in email/SMS marketing\n",
    "  - Age-appropriate advertising\n",
    "  - Reasonable promotional timing/frequency\n\n",
    "❌ PROHIBITED (harmful conduct):\n",
    "  - Health hazards: unsafe demonstrations, dangerous usage\n",
    "  - Mental harm: fear-mongering, exploiting insecurities excessively\n",
    "  - Moral harm: sexually explicit content, degrading imagery\n",
    "  - Distress: shock tactics, disturbing imagery\n",
    "  - Excessive inconvenience: spam, intrusive tactics, harassment\n\n",
    "Note: This evaluates HOW advertising is conducted, not WHAT is claimed.\n\n",
    "Key distinction: Respectful methods ✓ vs. harmful conduct ✗\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does the manner or content of this advertising cause harm to health,\n",
    "mentality, or morality, or cause distress or excessive inconvenience?\n\n",
    "Answer with:\n",
    "- YES (violates Article 42 - prohibited) or NO (acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// ============================================================================
// TIER 2: MANUAL-SPECIFIC PROMPTS (7 prompts - cross-cutting requirements)
// Source: Thai Cosmetics Manual BE 2567, Sections 4-9
// ============================================================================

// PROMPT 10: Ingredient Substantiation (Section 4.1)
promptIngredientSubstantiation claimText MEANS
  CONCAT
    "REGULATORY TEST: Ingredient Efficacy Substantiation (Manual Section 4.1)\n",
    "Context: Thai Cosmetics Manual BE 2567, Section 4.1\n\n",
    "Principle: Claims about ingredient efficacy must be supported by documentation\n",
    "showing: (1) the claimed property falls within cosmetic scope, AND (2) the\n",
    "ingredient is present in sufficient quantity to support the claim.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE (properly substantiated):\n",
    "  - Claims supported by academic documents, certificates, test results\n",
    "  - Ingredient present in sufficient quantity\n",
    "  - Property claimed is within cosmetic scope\n\n",
    "❌ PROHIBITED (lacks substantiation):\n",
    "  - Claims about ingredient efficacy without documentation\n",
    "  - Ingredient present but in insufficient quantity (\"fairy dusting\")\n",
    "  - Claims exceed cosmetic scope\n",
    "  - Documentation is non-credible or non-verifiable\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this ingredient efficacy claim LACK proper substantiation\n",
    "documentation, OR is the ingredient present in insufficient quantity?\n\n",
    "Answer with:\n",
    "- YES (lacks substantiation - prohibited) or NO (properly substantiated - acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 11: Cosmetic Scope (Section 4.2)
promptCosmeticScope claimText MEANS
  CONCAT
    "REGULATORY TEST: Cosmetic Scope Boundaries (Manual Section 4.2)\n",
    "Context: Thai Cosmetics Act Article 4 + Manual BE 2567, Section 4.2\n\n",
    "Principle: Cosmetics are for EXTERNAL use for: (1) cleansing, (2) beautifying,\n",
    "(3) changing physical appearance WITHOUT altering body structure, (4) controlling\n",
    "body odor, or (5) maintaining body parts in good condition.\n\n",
    "Decision Boundary:\n",
    "✅ WITHIN COSMETIC SCOPE:\n",
    "  - Cleansing, beautifying, temporary appearance changes\n",
    "  - Controlling odor, maintaining good condition\n",
    "  - Effects are: TEMPORARY, SUPERFICIAL, EXTERNAL\n\n",
    "❌ EXCEEDS COSMETIC SCOPE:\n",
    "  - ALTERING body structure (changing tissue, cells, organs)\n",
    "  - THERAPEUTIC effects (treating, preventing, curing disease)\n",
    "  - INTERNAL effects (affecting metabolism, circulation, hormones)\n",
    "  - PERMANENT changes (structural alterations that persist)\n",
    "  - DEEP tissue effects (beyond epidermis)\n",
    "  - FUNCTIONAL changes (affecting how body systems work)\n\n",
    "Key distinction: Temporary external cosmetic effects ✓ vs. structural/internal/\n",
    "therapeutic/permanent effects ✗\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this claim EXCEED the scope of cosmetics by implying structural\n",
    "alteration, therapeutic effects, internal effects, or permanent changes?\n\n",
    "Answer with:\n",
    "- YES (exceeds scope - prohibited) or NO (within scope - acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 12: Comparative Advertising (Section 5)
promptComparativeAdvertising claimText MEANS
  CONCAT
    "REGULATORY TEST: Comparative Advertising Rules (Manual Section 5)\n",
    "Context: Thai Cosmetics Manual BE 2567, Section 5\n\n",
    "Principle: Comparative advertising must be truthful, supported by evidence, not\n",
    "create social division, and should only compare advertiser's own products.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE:\n",
    "  - Compares advertiser's OWN products only\n",
    "  - Truthful and evidence-supported\n",
    "  - \"New formula vs. old formula\"\n\n",
    "❌ PROHIBITED:\n",
    "  - Compares with OTHER companies' products\n",
    "  - Compares with competitors by name or implication\n",
    "  - Creates social division\n",
    "  - \"Better than Brand X\", \"More effective than leading competitor\"\n\n",
    "Key distinction: Own-product comparison ✓ vs. competitor comparison ✗\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this comparative claim VIOLATE the rules by comparing with other\n",
    "companies' products, lacking evidence, or creating division?\n\n",
    "Answer with:\n",
    "- YES (violates comparative advertising rules - prohibited) or NO (complies - acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 13: Award/Certification (Section 6)
promptAwardCertification claimText MEANS
  CONCAT
    "REGULATORY TEST: Award/Certification Claims (Manual Section 6)\n",
    "Context: Thai Cosmetics Manual BE 2567, Section 6\n\n",
    "Principle: Claims about awards or certifications must refer to awards/marks\n",
    "directly related to the advertised cosmetic, be truthful, supported by evidence,\n",
    "and clearly indicate the awarding body and year.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE:\n",
    "  - Award directly related to advertised cosmetic\n",
    "  - Clearly indicates: awarding body AND year received\n",
    "  - \"Winner of [Award Name] 2024 from [Organization]\"\n\n",
    "❌ PROHIBITED:\n",
    "  - Award not related to specific product advertised\n",
    "  - Awarding body not indicated\n",
    "  - Year not specified\n",
    "  - \"Award-winning\" without specifics\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this award/certification claim VIOLATE the rules by being\n",
    "unrelated, false, lacking proper attribution (body/year), or misleading?\n\n",
    "Answer with:\n",
    "- YES (violates award/certification rules - prohibited) or NO (complies - acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 14: Academic Statistics (Section 7)
promptAcademicStatistics claimText MEANS
  CONCAT
    "REGULATORY TEST: Academic Reports/Statistics (Manual Section 7)\n",
    "Context: Thai Cosmetics Manual BE 2567, Section 7\n\n",
    "Principle: Claims based on academic reports or statistics must be verifiable,\n",
    "truthful according to cited source, with supporting evidence relevant to the\n",
    "ingredient or product being claimed.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE:\n",
    "  - Verifiable and truthful according to source\n",
    "  - Supporting evidence relevant to specific product/ingredient\n",
    "  - Proper attribution and context\n\n",
    "❌ PROHIBITED:\n",
    "  - Unverifiable claims\n",
    "  - Misrepresentation of source material\n",
    "  - Cherry-picking data\n",
    "  - Studies not relevant to product/ingredient\n\n",
    "Evaluate this claim: ", claimText, "\n\n",
    "Question: Does this academic/statistical claim LACK verifiability, misrepresent\n",
    "sources, or use irrelevant evidence?\n\n",
    "Answer with:\n",
    "- YES (violates academic/statistics rules - prohibited) or NO (proper use - acceptable)\n",
    "- Confidence: [0-100]%\n",
    "- Reasoning: [1-2 sentences explaining your judgment]"

// PROMPT 15: Monarchy Rules (Section 8)
promptMonarchyRules claimText MEANS
  CONCAT
    "REGULATORY TEST: Monarchy References (Manual Section 8)\n",
    "Context: Thai Cosmetics Manual BE 2567, Section 8\n\n",
    "Principle: Advertising must not falsely refer to the King, Queen, heir apparent,\n",
    "or regent without proper royal authorization.\n\n",
    "Decision Boundary:\n",
    "✅ ACCEPTABLE:\n",
