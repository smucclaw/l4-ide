// CATEGORY: Certified Products - Medical Symbols
promptCertifiedMedicalSymbols claimText MEANS
  CONCAT
    "REGULATORY TEST: Medical Symbols/Marks (Certified Products Category)\n",
    "Context: Thai Cosmetics Manual BE 2567, Category 21 (Certified Products), p.43\n\n",
