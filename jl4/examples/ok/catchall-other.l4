-- NO-FIRE control for the typo-binder hint: `other` is a common catch-all
-- name and resembles none of the uncovered constructors (green, blue) —
-- no hint, clean check.
DECLARE Color IS ONE OF red, green, blue

GIVEN c IS A Color
GIVETH A NUMBER
f c MEANS
  CONSIDER c
  WHEN red THEN 1
  WHEN other THEN 0

#EVAL f blue
