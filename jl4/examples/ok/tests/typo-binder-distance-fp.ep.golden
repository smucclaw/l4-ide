-- Documented residual false positive of the typo-binder hint, accepted
-- because the hint never blocks: `rest` is a perfectly legitimate catch-all
-- name, but it is one edit from the uncovered constructor `rent` (both
-- length >= 4), so the SInfo hint fires. This fixture pins that the file
-- still typechecks and evaluates fine — the hint is visible in the golden,
-- nothing more.
DECLARE Charge IS ONE OF rent, deposit, fee

GIVEN ch IS A Charge
GIVETH A NUMBER
classify ch MEANS
  CONSIDER ch
  WHEN deposit THEN 1
  WHEN fee THEN 2
  WHEN rest THEN 0

#EVAL classify rent
