-- Regression coverage for prelude's minimum/maximum, in both overloads.
-- The MAYBE NUMBER 'maximum' used to delegate to minimum1, and the MAYBE
-- NUMBER 'maximum1' used to fold with 'min' — both silently returned the
-- MINIMUM where the maximum was documented.
IMPORT prelude

#EVAL maximum (LIST 1, 3, 2)
#EVAL minimum (LIST 3, 1, 2)
#EVAL maximum (LIST (JUST 1), (JUST 3), (JUST 2))
#EVAL minimum (LIST (JUST 3), (JUST 1), (JUST 2))
