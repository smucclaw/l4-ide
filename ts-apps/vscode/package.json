{
  "name": "l4-vscode",
  "displayName": "L4 Rules-as-code",
  "description": "Write, test, and deploy legal rules as executable code — with a built-in Legalese AI chat, MCP for AI agents, WebMCP for browser AI, syntax highlighting, IntelliSense, ladder diagrams, and cloud deployment",
  "license": "Apache-2.0",
  "version": "1.4.0",
  "publisher": "legalese",
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "l4",
    "legal",
    "webmcp",
    "mcp",
    "jl4",
    "language",
    "legislation",
    "rules-as-code",
    "rules"
  ],
  "icon": "static/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "publishConfig": {
    "files": [
      "!**/.DS_Store",
      "!**/.vscode/**",
      "static",
      "out",
      "src"
    ]
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/legalese/l4-ide",
    "directory": "ts-apps/vscode"
  },
  "activationEvents": [
    "onLanguage:l4",
    "onView:l4.deployView"
  ],
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "l4-sidebar",
          "title": "L4",
          "icon": "static/l4-sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "l4-sidebar": [
        {
          "id": "l4.deployView",
          "name": "L4",
          "type": "webview"
        }
      ]
    },
    "configuration": [
      {
        "title": "L4 Language Server",
        "properties": {
          "jl4.serverExecutablePath": {
            "scope": "machine-overridable",
            "type": "string",
            "default": "",
            "markdownDescription": "Path to the `jl4-lsp` executable. Leave empty to use the bundled binary or find `jl4-lsp` on your PATH."
          },
          "jl4.trace.server": {
            "scope": "resource",
            "type": "string",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "default": "off",
            "description": "Traces the communication between VS Code and the language server."
          }
        }
      },
      {
        "title": "L4 Cloud Deploy",
        "properties": {
          "jl4.serviceUrl": {
            "scope": "resource",
            "type": "string",
            "default": "",
            "markdownDescription": "URL of the jl4-service for deploying rules (e.g. `http://localhost:8080`). Set this for self-hosted deployments. Leave empty to use Legalese Cloud login."
          },
          "jl4.serviceApiKey": {
            "scope": "resource",
            "type": "string",
            "default": "",
            "markdownDescription": "API key (`sk_...`) for authenticating with a self-hosted jl4-service. Not needed when using Legalese Cloud login."
          },
          "jl4.mcpPort": {
            "scope": "machine-overridable",
            "type": "number",
            "default": 19415,
            "markdownDescription": "Local port for the L4 MCP proxy server. Legalese AI (built in), Cursor, GitHub Copilot, and other MCP-speaking agents connect to this port to access L4 rules."
          }
        }
      },
      {
        "title": "Legalese AI",
        "properties": {
          "legaleseAi.localMode": {
            "scope": "machine-overridable",
            "type": "boolean",
            "default": false,
            "markdownDescription": "Run Legalese AI in local mode for development purposes."
          }
        }
      }
    ],
    "languages": [
      {
        "id": "l4",
        "aliases": [
          "l4"
        ],
        "extensions": [
          ".l4"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "l4.visualize",
        "title": "Show decision graph"
      },
      {
        "command": "l4.renderResult",
        "title": "Track result"
      },
      {
        "command": "l4.openSidebar",
        "title": "Open L4 Sidebar",
        "icon": "static/l4-editor-icon.svg"
      },
      {
        "command": "l4.installCli",
        "title": "L4: Install L4 CLI"
      },
      {
        "command": "legaleseAi.askAboutSelection",
        "title": "Ask Legalese AI about this",
        "category": "Legalese AI"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "l4.openSidebar",
          "when": "resourceLangId == l4",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "legaleseAi.askAboutSelection",
          "when": "editorHasSelection",
          "group": "1_legalese@1"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "l4-tools",
        "label": "L4 Tools"
      }
    ]
  },
  "prettier": "@repo/prettier-config",
  "dependencies": {
    "@repo/viz-expr": "*",
    "@repo/webview": "*",
    "jl4-client-rpc": "*",
    "minimatch": "^10.0.1",
    "vscode-languageclient": "^9.0.1",
    "vscode-messenger": "^0.5.1",
    "vscode-messenger-common": "^0.5.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.0",
    "@eslint/js": "^9.17.0",
    "@repo/eslint-config": "*",
    "@repo/prettier-config": "*",
    "@types/fs-extra": "^11.0.4",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.94.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.6.0",
    "babel-loader": "^9.2.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "fs-extra": "^11.2.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run lint && npm run bundle-esbuild",
    "build": "npm run clean && npm run prepare:webview && tsc -b tsconfig.json && npm run bundle-esbuild",
    "prepare:webview": "rm -rf ./static/webview && mkdir -p ./static/webview && cp -r ../webview/build/* ./static/webview/",
    "bundle-esbuild": "node scripts/build.mjs",
    "test": "tsc -b tsconfig.json && node --test out/unit-tests/*.test.js",
    "package": "npm run lint && npx vsce package",
    "dev": "npm run build --watch",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,md,mdx,css,yaml}\" --ignore-path ../../.prettierignore",
    "lint": "eslint --max-warnings=0 ./src",
    "lint-fix": "eslint ./src --fix",
    "clean": "git clean -fdx out || echo 'git not available'"
  }
}
